# ============================================================
# OpenClaw Telegram Quickstart - 환경 변수 설정
# ============================================================
# 이 파일을 .env로 복사한 뒤 값을 수정하세요:
#   cp .env.example .env
#
# .env 파일은 git에 커밋되지 않습니다 (gitignore 처리됨).

# === 필수: Telegram Bot Token ===
# 1. Telegram에서 @BotFather를 검색하세요
# 2. /newbot 명령으로 봇을 만드세요
# 3. 발급받은 토큰을 아래에 붙여넣으세요
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# === 필수: AI Provider API Key (하나만 선택) ===
# 사용할 AI 제공자의 주석(#)을 해제하고 키를 입력하세요.
# 기본값은 OpenAI입니다. 다른 제공자를 쓰려면 config/openclaw.json도 변경하세요.

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic Claude (https://console.anthropic.com/settings/keys)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Gemini (https://aistudio.google.com/apikey)
# GEMINI_API_KEY=your-gemini-key-here

# OpenRouter (https://openrouter.ai/keys) - 여러 모델을 하나의 키로
# OPENROUTER_API_KEY=sk-or-your-key-here

# === 선택 사항 ===
# Gateway 인증 토큰 (Control UI 접근 시 사용)
OPENCLAW_GATEWAY_TOKEN=quickstart-token

# 타임존
TZ=Asia/Seoul

# 포트 변경 (기본: 18789)
# OPENCLAW_PORT=18789
